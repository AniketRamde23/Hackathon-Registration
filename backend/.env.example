# ── SERVER ──────────────────────────────────────────
PORT=5000
NODE_ENV=development
FRONTEND_URL=http://localhost:3000
ADMIN_URL=http://localhost:3001
JUDGE_URL=http://localhost:3002

# ── DATABASE ─────────────────────────────────────────
MONGODB_URI=mongodb+srv://USERNAME:PASSWORD@cluster.mongodb.net/hackflow

# ── FIREBASE AUTH ─────────────────────────────────────
FIREBASE_PROJECT_ID=your-firebase-project-id
FIREBASE_PRIVATE_KEY="-----BEGIN PRIVATE KEY-----\n...\n-----END PRIVATE KEY-----\n"
FIREBASE_CLIENT_EMAIL=firebase-adminsdk@your-project.iam.gserviceaccount.com

# ── JWT ───────────────────────────────────────────────
JWT_SECRET=your-super-secret-jwt-key-minimum-32-chars
JWT_EXPIRES_IN=7d

# ── RAZORPAY ─────────────────────────────────────────
RAZORPAY_KEY_ID=rzp_test_xxxxxxxxxxxx
RAZORPAY_KEY_SECRET=your-razorpay-key-secret
RAZORPAY_WEBHOOK_SECRET=your-webhook-secret
HACKATHON_FEE=499  # Fee in INR (paise = 49900)

# ── STRIPE (optional fallback) ────────────────────────
STRIPE_SECRET_KEY=sk_test_xxxxxxxxxxxx
STRIPE_WEBHOOK_SECRET=whsec_xxxxxxxxxxxx

# ── SENDGRID ─────────────────────────────────────────
SENDGRID_API_KEY=SG.xxxxxxxxxxxx
SENDGRID_FROM_EMAIL=noreply@hackflow.com
SENDGRID_FROM_NAME=HackFlow Team

# ── CLOUDINARY ────────────────────────────────────────
CLOUDINARY_CLOUD_NAME=your-cloud-name
CLOUDINARY_API_KEY=your-api-key
CLOUDINARY_API_SECRET=your-api-secret

# ── QR CODE ──────────────────────────────────────────
QR_BASE_URL=https://hackflow.com/verify/

# ── CRON (auto-cancellation) ─────────────────────────
PAYMENT_TIMEOUT_HOURS=24
